# agentcode — gitignore
# ======================

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Python artifacts
__pycache__/
*.pyc
*.pyo

# Node
node_modules/

# IDE
.idea/
.vscode/

# Generated logs and temp files
*.log
.tmp

# Secrets and credentials — never commit these
.env
.env.*
*.pem
*.key
*.p12
*.pfx
credentials.json
credentials.yaml
secrets.json
secrets.yaml
service-account*.json
